+        # Build a weight-name filter so that tensors belonging to non-MTP
+        # layers are skipped *before* the disk read inside the safetensors
+        # iterator.  For a typical DeepSeek V3 checkpoint this avoids reading
+        # ~620 GB of main-model tensor data during the drafter load.
+        mtp_start = self.config.num_hidden_layers
