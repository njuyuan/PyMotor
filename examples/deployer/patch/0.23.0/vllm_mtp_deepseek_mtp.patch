+def _is_mtp_weight(name: str, mtp_start_layer_idx: int) -> bool:
+    """Return True if *name* belongs to an MTP layer."""
+    m = re.search(r"model\.layers\.(\d+)\.", name)
+    if m and int(m.group(1)) >= mtp_start_layer_idx:
+        return True
+    # Shared embed_tokens may be referenced by the first MTP layer
+    if "embed_tokens" in name and "model.layers" not in name:
+        return True
+    return False
+
